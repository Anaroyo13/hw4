<h1><%= @place["name"] %></h1>

<h2>My Entries</h2>

<div class="row">
  <% for entry in @entries %>
    <div class="col-md-4">
      <div class="card mb-4">
        <div class="card-body">
              <% if entry.image.attached? %>
                <%= image_tag entry.image, class: "img-fluid mb-2" %>
             <% end %>
          <h3 class="card-title"><%= entry["title"] %></h3>
          <h4 class="text-muted"><%= entry["occurred_on"] %></h4>
          <p class="card-text"><%= entry["description"] %></p>
        </div>
      </div>
    </div>
  <% end %>
</div>

<p>
  <a href="/entries/new?place_id=<%= @place["id"] %>" class="btn btn-primary">New Entry</a>
</p>

<p>
  <a href="/places" class="btn btn-secondary">Back to All Places</a>
</p>